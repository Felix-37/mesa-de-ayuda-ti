  {
    "id": "TC007",
    "title": "Create a new ticket without an attachment",
    "description": "Verifies a user can create a ticket without attaching a file and then see it listed on the dashboard.",
    "category": "Ticket Creation",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on \"Sign in\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on \"Crear\" or \"Crear Ticket\" navigation option to open the ticket creation page"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard/crear\""
      },
      {
        "type": "action",
        "description": "Type \"Sin acceso a VPN\" into the subject field"
      },
      {
        "type": "action",
        "description": "Type \"Desde hoy no puedo conectar a la VPN. Recibo un mensaje de autenticación fallida.\" into the description field"
      },
      {
        "type": "action",
        "description": "Select \"Red\" from the category dropdown"
      },
      {
        "type": "action",
        "description": "Select \"Media\" from the priority dropdown"
      },
      {
        "type": "action",
        "description": "Click \"Crear Ticket\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Sin acceso a VPN\" is visible"
      }
    ]
  },

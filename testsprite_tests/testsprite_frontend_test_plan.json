  {
    "id": "TC001",
    "title": "View Kanban board with tickets grouped into status columns",
    "description": "Verifies the dashboard Kanban board loads and shows ticket cards grouped under Nuevo, En Progreso, and Resuelto with key card details visible.",
    "category": "Kanban Board Management",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Iniciar sesión\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Nuevo\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"En Progreso\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Resuelto\" is visible"
      }
    ]
  },
